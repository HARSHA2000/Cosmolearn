# ─────────────────────────────────────────────────────────────────────────────
# CosmoLearn — train.cosmoverge.in
# Copy this file to .env.local and fill in the values before running locally.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Site URL (no trailing slash)
# Local: http://localhost:3000
# Production: https://train.cosmoverge.in
NEXT_PUBLIC_SITE_URL=https://train.cosmoverge.in

# ── Supabase ─────────────────────────────────────────────────────────────────
# Get from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — SERVER-SIDE ONLY. NEVER expose to the client/browser.
# Get from: Supabase → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Resend (email) ───────────────────────────────────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_your_api_key_here

# From address — must be verified in Resend (cosmoverge.in domain)
RESEND_FROM_EMAIL=noreply@cosmoverge.in

# Where trainer notification emails are sent
TRAINER_NOTIFICATION_EMAIL=harshith@cosmoverge.in
